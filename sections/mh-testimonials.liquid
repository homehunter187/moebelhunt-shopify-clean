{{ 'moebelhunt-premium.css' | asset_url | stylesheet_tag }}

<section class="mh-testi mh-section">
  <div class="page-width">
    <div class="mh-section-head">
      {%- if section.settings.heading != blank -%}<h2 class="mh-section-head__title">{{ section.settings.heading }}</h2>{%- endif -%}
    </div>
    <div class="mh-testi__grid">
      {%- for block in section.blocks -%}
        <figure class="mh-testi__card" {{ block.shopify_attributes }}>
          <div class="mh-stars">{% for i in (1..5) %}{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}{% endfor %}</div>
          <blockquote class="mh-testi__quote">{{ block.settings.quote }}</blockquote>
          <figcaption class="mh-testi__author">{{ block.settings.author }}</figcaption>
        </figure>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MH Bewertungen",
  "tag": "section",
  "class": "mh-section-wrap",
  "max_blocks": 9,
  "settings": [
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Was unsere Kunden sagen" }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Bewertung",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Zitat", "default": "Hervorragende Qualitaet und schnelle Lieferung. Sehr empfehlenswert!" },
        { "type": "text", "id": "author", "label": "Autor", "default": "Anna K." },
        { "type": "range", "id": "rating", "label": "Sterne", "min": 1, "max": 5, "step": 1, "default": 5 }
      ]
    }
  ],
  "presets": [
    {
      "name": "MH Bewertungen",
      "blocks": [
        { "type": "testimonial", "settings": { "author": "Anna K.", "quote": "Hervorragende Qualitaet und schnelle Lieferung." } },
        { "type": "testimonial", "settings": { "author": "Markus L.", "quote": "Das Sofa ist ein Traum. Beratung war top." } },
        { "type": "testimonial", "settings": { "author": "Sophie B.", "quote": "Endlich ein Shop mit echtem Premium-Gefuehl." } }
      ]
    }
  ]
}
{% endschema %}
