{{ 'moebelhunt-premium.css' | asset_url | stylesheet_tag }}

<section class="mh-editorial page-width mh-editorial--{{ section.settings.media_position }}">
  <div class="mh-editorial__media">
    {%- if section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '600, 900, 1200, 1400', sizes: '(min-width: 750px) 50vw, 100vw', alt: section.settings.heading }}
    {%- else -%}
      <div class="mh-editorial__placeholder"></div>
    {%- endif -%}
  </div>
  <div class="mh-editorial__content">
    {%- if section.settings.eyebrow != blank -%}<p class="mh-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
    {%- if section.settings.heading != blank -%}<h2 class="mh-editorial__title">{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.text != blank -%}<div class="mh-editorial__text rte">{{ section.settings.text }}</div>{%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link | default: '#' }}" class="mh-btn mh-btn--primary">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Premium Editorial",
  "tag": "section",
  "class": "mh-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Interior Curation" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Luxurioeses Wohnen beginnt mit den richtigen Proportionen" },
    { "type": "richtext", "id": "text", "label": "Text", "default": "<p>Moebelhunt by Inhofer verbindet ikonische Formen, hochwertige Materialien und eine beruhigte Bildsprache zu einem Einkaufserlebnis, das inspiriert und verkauft.</p>" },
    { "type": "image_picker", "id": "image", "label": "Bild" },
    {
      "type": "select", "id": "media_position", "label": "Bildposition", "default": "left",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ]
    },
    { "type": "text", "id": "button_label", "label": "Button", "default": "Inspiration ansehen" },
    { "type": "url", "id": "button_link", "label": "Button-Link" }
  ],
  "presets": [{ "name": "Premium Editorial" }]
}
{% endschema %}
