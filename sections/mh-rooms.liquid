{{ 'moebelhunt-premium.css' | asset_url | stylesheet_tag }}

<section class="mh-rooms mh-section">
  <div class="page-width">
    <div class="mh-section-head">
      {%- if section.settings.eyebrow != blank -%}<p class="mh-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
      {%- if section.settings.heading != blank -%}<h2 class="mh-section-head__title">{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.text != blank -%}<p class="mh-section-head__text">{{ section.settings.text }}</p>{%- endif -%}
    </div>
    <div class="mh-rooms__grid">
      {%- for block in section.blocks -%}
        <a href="{{ block.settings.link | default: '#' }}" class="mh-room" {{ block.shopify_attributes }}>
          <div class="mh-room__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 800 | image_tag: loading: 'lazy', widths: '300, 500, 800', sizes: '(min-width:750px) 33vw, 90vw', alt: block.settings.title }}
            {%- else -%}<div class="mh-room__ph"></div>{%- endif -%}
          </div>
          <span class="mh-room__title">{{ block.settings.title }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MH Raeume",
  "tag": "section",
  "class": "mh-section-wrap",
  "max_blocks": 12,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Wohnideen" },
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Raeume entdecken" },
    { "type": "textarea", "id": "text", "label": "Text", "default": "Lassen Sie sich fuer jeden Raum inspirieren." }
  ],
  "blocks": [
    {
      "type": "room",
      "name": "Raum",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Wohnzimmer" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MH Raeume",
      "blocks": [
        { "type": "room", "settings": { "title": "Wohnzimmer" } },
        { "type": "room", "settings": { "title": "Schlafzimmer" } },
        { "type": "room", "settings": { "title": "Esszimmer" } },
        { "type": "room", "settings": { "title": "Kueche" } },
        { "type": "room", "settings": { "title": "Buero" } },
        { "type": "room", "settings": { "title": "Garten" } }
      ]
    }
  ]
}
{% endschema %}
