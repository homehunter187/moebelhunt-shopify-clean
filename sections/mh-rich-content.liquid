{{ 'moebelhunt-premium.css' | asset_url | stylesheet_tag }}

<section class="mh-rich page-width">
  {%- if section.settings.heading != blank -%}<h2 class="mh-rich__title">{{ section.settings.heading }}</h2>{%- endif -%}
  {%- for block in section.blocks -%}
    {%- case block.type -%}
      {%- when 'text' -%}
        <div class="mh-rich__text rte" {{ block.shopify_attributes }}>{{ block.settings.content }}</div>
      {%- when 'faq' -%}
        <details class="mh-faq" {{ block.shopify_attributes }}>
          <summary>{{ block.settings.question }}</summary>
          <div class="rte">{{ block.settings.answer }}</div>
        </details>
    {%- endcase -%}
  {%- endfor -%}
</section>

{% schema %}
{
  "name": "MH Rich Content",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Überschrift" }
  ],
  "blocks": [
    {
      "type": "text",
      "name": "Text",
      "settings": [
        { "type": "richtext", "id": "content", "label": "Inhalt", "default": "<p>Text hinzufügen.</p>" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Frage", "default": "Frage?" },
        { "type": "richtext", "id": "answer", "label": "Antwort", "default": "<p>Antwort.</p>" }
      ]
    }
  ],
  "presets": [{ "name": "MH Rich Content" }]
}
{% endschema %}
