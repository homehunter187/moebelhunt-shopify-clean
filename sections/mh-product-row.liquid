{{ 'moebelhunt-premium.css' | asset_url | stylesheet_tag }}

<section class="mh-prow mh-section">
  <div class="page-width">
    <div class="mh-section-head mh-section-head--split">
      <div>
        {%- if section.settings.eyebrow != blank -%}<p class="mh-eyebrow">{{ section.settings.eyebrow }}</p>{%- endif -%}
        {%- if section.settings.heading != blank -%}<h2 class="mh-section-head__title">{{ section.settings.heading }}</h2>{%- endif -%}
      </div>
      {%- if section.settings.link_label != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="mh-link-more">{{ section.settings.link_label }}</a>
      {%- endif -%}
    </div>
    <div class="mh-prow__scroll">
      {%- for block in section.blocks -%}
        <article class="mh-pcard" {{ block.shopify_attributes }}>
          <a href="{{ block.settings.link | default: '#' }}" class="mh-pcard__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy', widths: '300, 450, 600', sizes: '(min-width:750px) 22vw, 70vw', alt: block.settings.title }}
            {%- else -%}<div class="mh-pcard__ph"></div>{%- endif -%}
            {%- if block.settings.badge != blank -%}<span class="mh-pcard__badge">{{ block.settings.badge }}</span>{%- endif -%}
          </a>
          <div class="mh-pcard__body">
            {%- if block.settings.rating != blank -%}<div class="mh-stars" aria-label="Bewertung {{ block.settings.rating }} von 5">{% for i in (1..5) %}{% if i <= block.settings.rating %}&#9733;{% else %}&#9734;{% endif %}{% endfor %}</div>{%- endif -%}
            <a href="{{ block.settings.link | default: '#' }}" class="mh-pcard__title">{{ block.settings.title }}</a>
            <div class="mh-pcard__prices">
              <span class="mh-pcard__price">{{ block.settings.price }}</span>
              {%- if block.settings.compare_price != blank -%}<span class="mh-pcard__compare">{{ block.settings.compare_price }}</span>{%- endif -%}
            </div>
            <a href="{{ block.settings.link | default: '#' }}" class="mh-btn mh-btn--primary mh-btn--sm">Ansehen</a>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "MH Produktreihe",
  "tag": "section",
  "class": "mh-section-wrap",
  "max_blocks": 16,
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Ausgewaehlt" },
    { "type": "text", "id": "heading", "label": "Ueberschrift", "default": "Bestseller" },
    { "type": "text", "id": "link_label", "label": "Mehr-Link Text", "default": "Alle ansehen" },
    { "type": "url", "id": "link_url", "label": "Mehr-Link Ziel" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Produkt",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Bild" },
        { "type": "text", "id": "title", "label": "Titel", "default": "Premium Sofa" },
        { "type": "text", "id": "price", "label": "Preis", "default": "1.299 \u20ac" },
        { "type": "text", "id": "compare_price", "label": "Alter Preis", "default": "1.599 \u20ac" },
        { "type": "range", "id": "rating", "label": "Bewertung", "min": 0, "max": 5, "step": 1, "default": 5 },
        { "type": "text", "id": "badge", "label": "Badge", "default": "Sale" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "MH Produktreihe",
      "blocks": [
        { "type": "product", "settings": { "title": "Samt-Sofa Milano", "price": "1.299 \u20ac", "compare_price": "1.599 \u20ac" } },
        { "type": "product", "settings": { "title": "Eichentisch Nordic", "price": "899 \u20ac", "compare_price": "1.090 \u20ac" } },
        { "type": "product", "settings": { "title": "Boxspringbett Luxe", "price": "1.490 \u20ac", "compare_price": "1.790 \u20ac" } },
        { "type": "product", "settings": { "title": "Sessel Cozy", "price": "549 \u20ac", "compare_price": "699 \u20ac" } },
        { "type": "product", "settings": { "title": "Esszimmerstuhl Set", "price": "399 \u20ac", "compare_price": "499 \u20ac" } },
        { "type": "product", "settings": { "title": "Gartenlounge Terra", "price": "1.190 \u20ac", "compare_price": "1.490 \u20ac" } },
        { "type": "product", "settings": { "title": "Sideboard Vela", "price": "749 \u20ac", "compare_price": "899 \u20ac" } },
        { "type": "product", "settings": { "title": "Regal Skyline", "price": "329 \u20ac", "compare_price": "429 \u20ac" } }
      ]
    }
  ]
}
{% endschema %}
